{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "eslint-config-heck/biomeJsTs"
  ],
  "linter": {
    "rules": {
      "complexity": {
        "noExcessiveCognitiveComplexity": "off"
      },
      "nursery": {
        "noShadow": "off"
      },
      "performance": {
        "noBarrelFile": "off"
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "lineWidth": 130
  },
  "json": {
    "parser": {
      "allowComments": true
    }
  }
}