{
  "compilerOptions": {
    "esModuleInterop": true,
    "noImplicitAny": true,
    "isolatedModules": true,
    "lib": ["ESNext"],
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "target": "esnext",
    "strictNullChecks": true,
    "importHelpers": true,
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["jest", "node"]
  },
  "include": ["src/**/*", "tests/**/*"]
}